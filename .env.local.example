# ─── EmailJS — نموذج تحميل الوثائق ───────────────────────────────────────────
# للحصول على هذه القيم:
#   1. اذهب إلى https://www.emailjs.com وسجّل حساباً مجانياً
#   2. Service ID: من قسم Email Services → أضف خدمة Gmail وانسخ الـ ID
#   3. Template ID: من قسم Email Templates → أنشئ قالباً جديداً (تعليمات أدناه)
#   4. Public Key: من Account → API Keys → انسخ الـ Public Key

NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# ─── قالب البريد (Email Template) ────────────────────────────────────────────
# أنشئ قالباً في EmailJS بالمحتوى التالي:
#
# Subject: طلب تحميل وثيقة — {{file_name}}
#
# Body:
#   تفاصيل طلب التحميل:
#   ───────────────────
#   الوثيقة:            {{file_name}}
#   وقت التحميل:        {{download_time}}
#
#   بيانات المستخدم:
#   ────────────────
#   الاسم:              {{user_name}}
#   الجوال:             {{user_phone}}
#   البريد:             {{user_email}}
#   الجهة / المنظمة:    {{user_org}}
#
# To Email: mushataltaif@gmail.com
