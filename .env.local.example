# ─── EmailJS ─────────────────────────────────────────────────────────────────
# للحصول على هذه القيم:
#   1. اذهب إلى https://www.emailjs.com وسجّل حساباً مجانياً
#   2. Service ID: من قسم Email Services → أضف خدمة Gmail وانسخ الـ ID
#   3. Template IDs: من قسم Email Templates → أنشئ قالبَين (تعليمات أدناه)
#   4. Public Key: من Account → API Keys → انسخ الـ Public Key

NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# قالب نموذج تحميل الوثائق
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx

# قالب نموذج التواصل (اختياري — يرجع إلى TEMPLATE_ID إن لم يُحدَّد)
NEXT_PUBLIC_EMAILJS_CONTACT_TEMPLATE_ID=template_xxxxxxx

# ─── قالب تحميل الوثائق ──────────────────────────────────────────────────────
# Subject: طلب تحميل وثيقة — {{file_name}}
#
# Body:
#   الوثيقة:            {{file_name}}
#   وقت التحميل:        {{download_time}}
#   الاسم:              {{user_name}}
#   الجوال:             {{user_phone}}
#   البريد:             {{user_email}}
#   الجهة / المنظمة:    {{user_org}}
#
# ─── قالب التواصل ────────────────────────────────────────────────────────────
# Subject: رسالة تواصل — {{user_subject}}
#
# Body:
#   الاسم:              {{user_name}}
#   البريد:             {{user_email}}
#   الجوال:             {{user_phone}}
#   الموضوع:            {{user_subject}}
#   وقت الإرسال:        {{send_time}}
#
#   الرسالة:
#   {{user_message}}
#
# To Email: mushataltaif@gmail.com
